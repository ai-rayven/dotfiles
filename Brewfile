# Homebrew dependencies for this dotfiles setup.
# Install with: brew bundle --file=Brewfile  (setup.sh does this automatically)

brew "neovim"   # `vim`/`vi` aliases + nvim/ config
brew "tmux"     # tmux.conf
brew "nvm"      # sourced from zshrc; manages node
brew "git"      # lazy.nvim clone, general use

cask "wezterm"  # wezterm/ config
